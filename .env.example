# ==============================================================================
# 📂 GLOBAL DIRECTORIES & PATHS
# ==============================================================================
# Note: /opt/scripts and /opt/venv are foundational paths created by setup.sh. 
# If you want to change them, update setup.sh first.

# @USED_BY: crontab
export PATH="/opt/venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

# @USED_BY: crontab, backup-scripts-git.sh, local-opt-backup.sh
export CTRL_DIR="$(eval echo ~$(stat -c '%U' /opt/scripts))/ctrl_s_master"

# @USED_BY: crontab, backup-scripts-git.sh, local-opt-backup.sh, gitops-deploy.sh, generate-dashboards.sh
export STACKS_DIR='/opt/stacks'

# @USED_BY: crontab, setup.sh, nextcloud-dynamic-watch.sh
export DATA_DIR='/data/assets'

# @USED_BY: setup.sh, nextcloud-dynamic-watch.sh
NEXTCLOUD_DATA_DIR='/data/nextcloud_data'

# @USED_BY: local-opt-backup.sh, health-snapshot.sh
BACKUP_DIR=''

# ==============================================================================
# 🔑 SECRETS & CREDENTIALS
# ==============================================================================

# @USED_BY: local-opt-backup.sh
AGE_KEYFILE=''

# @USED_BY: cron-guard.py, container-watcher.sh, gitops-deploy.sh
TELEGRAM_DANTE_BOT_TOKEN=''
TELEGRAM_CHAT_ID=''

# @USED_BY: container-watcher.sh
N8N_WEBHOOK_UUID=''

# ==============================================================================
# 🌐 EXTERNAL SERVICES & HEALTHCHECKS
# ==============================================================================

# @USED_BY: crontab
NEXTDNS_URL=''
SERVER_HC_URL=''

# @USED_BY: local-opt-backup.sh
KUMA_HC_URL=''

# ==============================================================================
# 🛠️ SCRIPT CONFIGURATIONS
# ==============================================================================

# @USED_BY: cleanup_script.py
FILES_TO_KEEP='2'

# @USED_BY: backup-scripts-git.sh
TOOLS='btop fastfetch'

# @USED_BY: setup.sh
SERVER_IP='192.168.1.x'
TIMEZONE='Africa/Cairo'

# ==============================================================================
# 🐳 SERVICE CONFIGURATIONS
# ==============================================================================

# @USED_BY: nextcloud_post-restore_fix.sh, nextcloud-dynamic-watch.sh
NEXTCLOUD_USER=''
NEXTCLOUD_CONTAINER='nextcloud'

# @USED_BY: nextcloud-dynamic-watch.sh
NEXTCLOUD_MOUNT_NAME='assets'

# ==============================================================================
# 👻 GHOST WATCHER TASK REGISTRY
# ==============================================================================
# To add a new container watcher, add a new line inside the quotes below.
#
# FORMAT: task_name|container_name
#  - task_name:      Must match task_<name>() in container-watcher.sh
#  - container_name: The exact Docker container name to monitor
#
# EXAMPLE: radarr|radarr
# ==============================================================================
# @USED_BY: container-watcher.sh
WATCHER_TASKS="
nextcloud|nextcloud
tailscale|tailscaled
npm|npm
pihole|pihole
"
