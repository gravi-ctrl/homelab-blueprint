export CTRL_DIR='/home/gravi-ctrl/ctrl_s_master'

# @USED_BY: crontab, setup.sh, nextcloud-dynamic-watch.sh
export DATA_DIR='/data/assets'

# @USED_BY: setup.sh, nextcloud-dynamic-watch.sh
NEXTCLOUD_DATA_DIR='/data/nextcloud_data'

# @USED_BY: local-opt-backup.sh
BACKUP_DIR=''

# @USED_BY: backup-scripts-git.sh, local-opt-backup.sh
STACKS_DIR=''

# ==============================================================================
# 🔑 SECRETS & CREDENTIALS
# ==============================================================================

# @USED_BY: local-opt-backup.sh
AGE_KEYFILE='/root/.backup-key.txt'

# @USED_BY: cron-guard.py, container-watcher.sh
TELEGRAM_DANTE_BOT_TOKEN=''
TELEGRAM_CHAT_ID=''

# @USED_BY: container-watcher.sh
N8N_WEBHOOK_UUID=''

# ==============================================================================
# 🌐 EXTERNAL SERVICES & HEALTHCHECKS
# ==============================================================================

# @USED_BY: crontab
NEXTDNS_URL=''
SERVER_HC_URL=''

# @USED_BY: local-opt-backup.sh
KUMA_HC_URL=''

# ==============================================================================
# 🛠️ SCRIPT CONFIGURATIONS
# ==============================================================================

# @USED_BY: cleanup_script.py
FILES_TO_KEEP='2'

# @USED_BY: backup-scripts-git.sh
TOOLS='btop fastfetch'

# @USED_BY: setup.sh
SERVER_IP='192.168.1.x'
TIMEZONE='Africa/Cairo

# @USED_BY: nextcloud_post-restore_fix.sh, nextcloud-dynamic-watch.sh
NEXTCLOUD_USER=''
NEXTCLOUD_CONTAINER='nextcloud'

# @USED_BY: nextcloud-dynamic-watch.sh
NEXTCLOUD_MOUNT_NAME='assets

# ==============================================================================
# 👻 GHOST WATCHER TASK REGISTRY
# ==============================================================================
# To add a new container watcher, simply add a new line inside the quotes below.
#
# FORMAT: task_name|container_name|optional_custom_check
#  - task_name: Must match the function name task_<name>() in container-watcher.sh
#  - container_name: The exact Docker container name to monitor for a "running" state
#  - optional_custom_check: A bash command evaluated to verify internal readiness
#
# EXAMPLE: radarr|radarr|
# ==============================================================================

# @USED_BY: container-watcher.sh
WATCHER_TASKS="
nextcloud|nextcloud|docker exec nextcloud test -f /var/www/html/lib/versioncheck.php 2>/dev/null
tailscale|tailscaled|
npm|npm|
"