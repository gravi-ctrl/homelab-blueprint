# ==============================================================================
# 📂 GLOBAL DIRECTORIES & PATHS
# ==============================================================================
export S="/home/gravi-ctrl/scripts"       # [crontab]
export C="/home/gravi-ctrl/ctrl_s_master" # [crontab]
export A="/data/assets"                   # [crontab]
BACKUP_DIR=''                             # [local-opt-backup.sh]
STACKS_DIR=''                             # [bootstrap.sh, backup-scripts-git.sh, local-opt-backup.sh]

# ==============================================================================
# 🔑 SECRETS & CREDENTIALS
# ==============================================================================
AGE_KEYFILE='/root/.backup-key.txt'       # [bootstrap.sh, local-opt-backup.sh]
TELEGRAM_DANTE_BOT_TOKEN=''               # [cron-guard, container-watcher.sh]
TELEGRAM_CHAT_ID=''                       # [cron-guard, container-watcher.sh]

# ==============================================================================
# 🌐 HEALTHCHECKS & API URLS
# ==============================================================================
NEXTDNS_URL=''                            # [crontab]
SERVER_HC_URL=''                          # [crontab]
KUMA_HC_URL=''                            # [local-opt-backup.sh]
N8N_WEBHOOK_UUID=''                       # [container-watcher.sh]

# ==============================================================================
# 🛠️ SCRIPT-SPECIFIC CONFIGURATIONS
# ==============================================================================
FILES_TO_KEEP='2'                         # [cleanup_script.py]
TOOLS='btop fastfetch'                    # [backup-scripts-git.sh]

# ==============================================================================
# 👻 GHOST WATCHER TASK REGISTRY [container-watcher.sh]
# ==============================================================================
# To add a new container watcher, simply add a new line inside the quotes below.
#
# FORMAT: task_name|container_name|optional_custom_check
#  - task_name: Must match the function name task_<name>() in container-watcher.sh
#  - container_name: The exact Docker container name to monitor for a "running" state
#  - optional_custom_check: A bash command evaluated to verify internal readiness
#
# EXAMPLE: radarr|radarr|
# ==============================================================================
WATCHER_TASKS="
nextcloud|nextcloud|docker exec nextcloud test -f /var/www/html/lib/versioncheck.php 2>/dev/null
tailscale|tailscaled|
npm|npm|
"