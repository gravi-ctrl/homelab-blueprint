# =================================================================
#               MASTER AUTOMATION CONFIGURATION
# =================================================================

# --- Master Script Secrets & Config ---
# Passwords for Bitwarden personal and work vaults - in case if 'encrypted_json' as the EXPORT_FORMAT is chosen
# THIS IS NOT your master password. It's a separate password to encrypt the backup file.
BITWARDEN_PERSONAL_PASSWORD=                                # Your password of choice for the personal Bitwarden vault 
BITWARDEN_WORK_PASSWORD=                                    # Your password of choice for the work Bitwarden vault 

# Passwords for the final KeePass database files (.kdbx). This is what you will use to open them in KeePassXC.
KDBX_PERSONAL_PASSWORD=                                     # Password for your personal KeePass database (.kdbx)
KDBX_WORK_PASSWORD=                                         # Password for your work KeePass database (.kdbx)

FFS_PATH=src/_tools/FreeFileSync/FreeFileSync.exe           # Full path to FreeFileSync executable, e.g. C:/Program Files/FreeFileSync/FreeFileSync.exe

# Paths to the worker scripts, relative to the project root. (Keep these as default).
RAINDROP_BACKUP_SCRIPT_PATH=src/_tools/raindrop_backup.py   # Path to your Raindrop.io backup script
BW_EXPORT_SCRIPT_PATH=src/_tools/bitwarden_exporter.py      # Path to your Bitwarden export script

# =================================================================
#               MASTER SCRIPT BEHAVIOR
# =================================================================

CONTINUE_ON_ERROR=true                                      # Set to 'true' to continue to the next task if one fails; 'false' to stop on the first error.

# =================================================================
#               BITWARDEN EXPORTER CONFIGURATION
# =================================================================

# --- Shared Bitwarden API & CLI Settings ---
BW_API_URL=https://vault.bitwarden.com/api                  # Bitwarden API base URL (usually keep default)
BW_IDENTITY_URL=https://vault.bitwarden.com/identity        # Bitwarden Identity service URL (default)
BW_ACCESS_TOKEN=                                            # OAuth or API access token if applicable
BW_STATE_FILE=src/_tools/statefile.json                     # Local file to keep track of last export state
BW_CLI_PATH=src/_tools/bw/bw.exe                            # Path to Bitwarden CLI 
BW_VAULTS_DIR=vaults                                        # Directory where vault export files will be saved
BW_SERIALS_TO_KEEP=5                                        # The maximum number of serial-numbered backups to retain; 0 keeps all files.

# --- Personal Vault Settings ---
# Credentials and export options for your personal Bitwarden vault
BW_PERSONAL_CLIENT_ID_UUID=                                 # OAuth client ID for personal vault
BW_PERSONAL_CLIENT_SECRET_UUID=                             # OAuth client secret for personal vault
BW_PERSONAL_MASTER_PASSWORD_UUID=                           # Your personal vault master password or secret
BW_PERSONAL_OUTPUT_FILENAME=personal.json                   # Output filename for personal vault export
BW_PERSONAL_EXPORT_FORMAT=encrypted_json                    # Export formats are: encrypted_json, json, csv and zip
BW_PERSONAL_IS_ORGANIZATION=false                           # Set to 'true' if exporting an organization vault
BW_PERSONAL_ORGANIZATION_ID=                                # Organization ID if applicable

# --- Work Vault Settings ---
# Credentials and export options for your work Bitwarden vault
BW_WORK_CLIENT_ID_UUID=                                     # OAuth client ID for work vault
BW_WORK_CLIENT_SECRET_UUID=                                 # OAuth client secret for work vault
BW_WORK_MASTER_PASSWORD_UUID=                               # Your work vault master password or secret
BW_WORK_OUTPUT_FILENAME=work.json                           # Output filename for work vault export
BW_WORK_EXPORT_FORMAT=encrypted_json                        # Export formats are: encrypted_json, json, csv and zip
BW_WORK_IS_ORGANIZATION=true                                # Usually true for work vaults
BW_WORK_ORGANIZATION_ID=                                    # Organization ID for work vault

# =================================================================
#               RAINDROP.IO BACKUP CONFIGURATION
# =================================================================

RAINDROP_PERSONAL_API_TOKEN=                                # Your personal Raindrop.io API token
RAINDROP_WORK_API_TOKEN=                                    # Your work Raindrop.io API token (if applicable)
RAINDROP_BACKUP_DESTINATION=                                # Backup destination path where Raindrop backups should be saved

# Controls cleanup for both Raindrop backups.
BACKUPS_TO_KEEP=2                                           # The maximum number of backups to retain; 0 keeps all files.

# =================================================================
#                EMAIL NOTIFICATION VARIABLES
# =================================================================

EMAIL_HOST=smtp.gmail.com                                   # Your SMTP email server hostname
EMAIL_PORT=465                                              # SMTP port (465 for SSL, 587 for TLS)
EMAIL_SENDER=                                               # Sender email address (e.g. your_email@gmail.com)
EMAIL_PASSWORD=                                             # App-specific password for the sender account
EMAIL_RECIPIENT=                                            # Email address to receive status reports

# =================================================================
#                EMAIL ATTACHMENT CONFIGURATION
# =================================================================

EMAIL_ATTACH_LOGS=run_*.log,sync-2fa*.*,sync-backups*.*     # Comma-separated list of log patterns to attach to emails; only the newest file for each pattern is sent.

# =================================================================
#                END OF CONFIGURATION TEMPLATE
# =================================================================
