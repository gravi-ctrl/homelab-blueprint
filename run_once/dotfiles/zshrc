# Universal Archive Extractor
extract() {
    if [[ -f "$1" ]]; then
        # 1. Determine the target directory name (remove extension)
        local dir="${1%.*}"

        # Handle the .tar.gz / .tar.bz2 case where %.* only removes the last part
        if [[ "$1" =~ \.tar\..+$ ]]; then
            dir="${dir%.*}"
        fi

        # 2. Create and prepare directory
        if [[ -d "$dir" ]]; then
            echo "Error: Directory '$dir' already exists. Aborting to prevent overwrite."
            return 1
        fi

        mkdir -p "$dir"

        # 3. Extraction logic
        case "$1" in
            *.tar.bz2|*.tbz2|*.tar.gz|*.tgz|*.tar.xz|*.tar)
                         tar -xf "$1" -C "$dir" ;;
            *.zip)       unzip "$1" -d "$dir" ;;
            *.rar)       unrar x "$1" "$dir/" ;; # 'x' preserves path structure
            *.7z)        7z x "$1" -o"$dir"    ;; # -o must be attached to the path
            *.bz2)       bunzip2 -c "$1" > "$dir/${1%.*}" ;;
            *.gz)        gunzip -c "$1" > "$dir/${1%.*}"  ;;
            *.Z)         uncompress -c "$1" > "$dir/${1%.*}" ;;
            *)           echo "Error: '$1' cannot be extracted via extract()"
                         rmdir "$dir"
                         return 1 ;;
        esac

        echo "Successfully extracted '$1' into '$dir/'"
    else
        echo "Error: '$1' is not a valid file"
    fi
}

# Git auto-commit alert (with subdirectory support)
typeset -A _commit_zones_seen

_find_commit_zone() {
    local dir="$PWD"
    while [[ "$dir" != "/" ]]; do
        [[ -f "$dir/.commit-warning" ]] && { echo "$dir"; return 0; }
        dir="${dir:h}"
    done
    return 1
}

chpwd() {
    local zone
    zone=$(_find_commit_zone) || return

    [[ -n "${_commit_zones_seen[$zone]}" ]] && return
    _commit_zones_seen[$zone]=1

    echo
    echo -e "\033[1;31m⚠️ GIT AUTO-COMMIT\033[0m \033[90m$zone\033[0m"
    grep -Ev '^#|^\s*$' "$zone/.commit-warning" | while read -r line; do
        echo -e "  ↻ \033[3;97m$line\033[0m"
    done
}

