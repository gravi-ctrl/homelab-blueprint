# ─────────────────────────────────────────────────────────────────
#  docker_dash — configuration
#  Copy this file to .env, fill in your values, then run:
#      python3 docker_dash.py
# ─────────────────────────────────────────────────────────────────

# ── GitHub repo ───────────────────────────────────────────────────
# Public GitHub repo containing your compose stacks
GITHUB_REPO=''
GITHUB_BRANCH='main'

# Comma-separated folder names to skip (e.g. archived stacks)
EXCLUDE_DIRS=''

# ── Nginx Proxy Manager API ───────────────────────────────────────
# Base URL of your NPM instance (no trailing slash)
# Example: http://192.168.1.10:81  or  https://npm.yourdomain.com
NPM_URL=''

# NPM login credentials (same ones you use in the web UI)
NPM_EMAIL=''
NPM_PASSWORD=''

# ── Output ────────────────────────────────────────────────────────
# Where to write the generated dashboard HTML
OUTPUT_FILE=index.html
