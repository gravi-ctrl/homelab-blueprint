#!/bin/bash
# @DESCRIPTION: Triggers the running wifi-robot container via HTTP
# @FREQUENCY: On Demand

# -------------------

if [ -z "$1" ]; then
    echo "Error: Please specify 'on' or 'off'."
    echo "Usage: guestwifi on"
    exit 1
fi

echo "Sending signal '$1' to Wi-Fi Robot..."

docker exec wifi-robot curl -s "http://localhost:5000/$1"



