#!/bin/bash
# @DESCRIPTION: Triggers the running wifi_robot container via HTTP
# @FREQUENCY: On Demand

# USAGE: guestwifi on (to turn Guest Wi-Fi ON) guestwifi off (to turn it OFF)

# -------------------

if [ -z "$1" ]; then
    echo "Error: Please specify 'on' or 'off'."
    echo "Usage: guestwifi on"
    exit 1
fi

echo "Sending signal '$1' to Wi-Fi Robot..."

curl -s "http://localhost:5050/$1"



