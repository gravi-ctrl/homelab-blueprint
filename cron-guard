#!/bin/bash
# @DESCRIPTION: Runs a command, captures output, and Telegrams on failure with logs (needs to be copied to /usr/local/bin/)
# @FREQUENCY: On Failure

# INSTALL
# sudo cp cron-guard /usr/local/bin/
# sudo chmod +x /usr/local/bin/cron-guard
#
# USAGE: cron-guard "NAME OF JOB" command_to_run
# For multiple commands involving '&&' or '|', use sh -c then wrap the whole command between '...'
# Example: /usr/local/bin/cron-guard "Test" sh -c 'cd /path/of/the/file && rm file'

# ------

set -o pipefail

# --- CONFIG ---
TOKEN="TELEGRAM_BOT_TOKEN"
CHAT_ID="YOUR_CHAT_ID"
# --------------

# 1. Extract the Job Name (First Argument)
JOB_NAME="$1"
shift 1 # Remove the name, leaving only the command to run

# 2. Run the command, capture standard output AND errors
# We capture the output into a variable
OUTPUT=$("$@" 2>&1)
EXIT_CODE=$?

# 3. If the command failed (Exit code is not 0)
if [ $EXIT_CODE -ne 0 ]; then
    
    # Get current date
    DATE_TIME=$(date "+%Y-%m-%d %H:%M:%S")

    # Grab the last 10 lines of the log (to keep telegram msg short)
    LOG_TAIL=$(echo "$OUTPUT" | tail -n 10)

    # If log is empty, put a placeholder
    if [ -z "$LOG_TAIL" ]; then
        LOG_TAIL="No output generated."
    fi

    # Prepare the message using Markdown
    TEXT=$(printf "🚨 *CRON FAILURE*\n\n📂 *Job:* %s\n⏰ *Time:* %s\n🔢 *Exit Code:* %s\n\n📜 *Error Log (Last lines):*\n\`\`\`\n%s\n\`\`\`" \
    "$JOB_NAME" "$DATE_TIME" "$EXIT_CODE" "$LOG_TAIL")

    # Send to Telegram
    curl -s -X POST "https://api.telegram.org/bot$TOKEN/sendMessage" \
        -d chat_id="$CHAT_ID" \
        -d parse_mode="Markdown" \
        --data-urlencode "text=$TEXT" > /dev/null
fi

# Pass the exit code back to Cron (so Cron knows it failed too)
exit $EXIT_CODE
