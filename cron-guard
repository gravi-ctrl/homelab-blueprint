#!/bin/bash
# @DESCRIPTION: Runs a command, captures output, and Telegrams on failure with logs (needs to be copied to /usr/local/bin/)
# @FREQUENCY: On Failure

# INSTALL
# sudo cp cron-guard /usr/local/bin/
# sudo chmod +x /usr/local/bin/cron-guard
#
# USAGE: cron-guard "NAME OF JOB" command_to_run
# For multiple commands involving '&&' or '|', use sh -c then wrap the whole command between '...'
# Example: /usr/local/bin/cron-guard "Test" sh -c 'cd /path/of/the/file && rm file'

# ------

set -o pipefail

# --- 1. CONFIG LOADER ---
ENV_FILE="/home/gravi-ctrl/scripts/.env"

if [ -f "$ENV_FILE" ]; then
    set -a
    source "$ENV_FILE"
    set +a
fi

# --- 2. VARIABLE MAPPING ---
TOKEN="${TELEGRAM_DANTE_BOT_TOKEN:-YOUR_HARDCODED_TOKEN_HERE}"
CHAT_ID="${TELEGRAM_CHAT_ID:-YOUR_HARDCODED_CHAT_ID_HERE}"

# --- 3. SAFETY CHECK ---
if [[ "$TOKEN" == "YOUR_HARDCODED_*" ]] || [ -z "$TOKEN" ]; then
    "$@"
    exit $?
fi

# --- 4. EXECUTION ---
JOB_NAME="$1"
shift 1 

OUTPUT=$("$@" 2>&1)
EXIT_CODE=$?

# --- 5. FAILURE HANDLING ---
if [ $EXIT_CODE -ne 0 ]; then
    DATE_TIME=$(date "+%Y-%m-%d %H:%M:%S")
    LOG_TAIL=$(echo "$OUTPUT" | tail -n 10)

    TEXT=$(printf "🚨 *CRON FAILURE*\n\n📂 *Job:* %s\n⏰ *Time:* %s\n🔢 *Exit Code:* %s\n\n📜 *Log:*\n\`\`\`\n%s\n\`\`\`" \
    "$JOB_NAME" "$DATE_TIME" "$EXIT_CODE" "${LOG_TAIL:-No output.}")

    curl -s -X POST "https://api.telegram.org/bot$TOKEN/sendMessage" \
        -d chat_id="$CHAT_ID" \
        -d parse_mode="Markdown" \
        --data-urlencode "text=$TEXT" > /dev/null 2>&1
fi

exit $EXIT_CODE
