# =================================================================
#               MASTER AUTOMATION CONFIGURATION
#
#  This file works for BOTH Windows and Linux.
#  Platform-specific vars are marked accordingly.
# =================================================================


# =================================================================
#               MASTER SCRIPT SECRETS
# =================================================================

# Passwords used to encrypt the Bitwarden JSON export files.
# (Only needed if BW_*_EXPORT_FORMAT=encrypted_json)
# This is NOT your master password — it's a separate backup encryption password of your choice.
BITWARDEN_PERSONAL_PASSWORD=
BITWARDEN_WORK_PASSWORD=

# Passwords to open the final KeePass .kdbx files in KeePassXC.
KDBX_PERSONAL_PASSWORD=
KDBX_WORK_PASSWORD=


# =================================================================
#               MASTER SCRIPT BEHAVIOUR
# =================================================================

CONTINUE_ON_ERROR=true          # 'true' = keep going if one task fails; 'false' = stop immediately


# =================================================================
#               PATHS TO WORKER SCRIPTS
# =================================================================

RAINDROP_BACKUP_SCRIPT_PATH=src/_tools/raindrop_backup.py
BW_EXPORT_SCRIPT_PATH=src/_tools/bitwarden_exporter.py


# =================================================================
#               SYNC CONFIGURATION
# =================================================================
# File syncing is fully automated based on the configuration files you 
# drop into the respective tool folders. No code changes are required.

# --- [WINDOWS ONLY] FreeFileSync ---
# To add a sync job: Drop FreeFileSync batch scripts (*.ffs_batch) into src/_tools/ffs_jobs/
# Path to FreeFileSync executable. Can be relative to project root or absolute.
FFS_PATH=src/_tools/FreeFileSync/FreeFileSync.exe

# --- [LINUX ONLY] rsync ---
# To add a sync job: Drop JSON configuration files (*.json) into src/_tools/rsync_jobs/
#
# (Optional) You can define custom variables below to keep your JSON files clean and portable.
# Any variable defined here can be referenced in your JSON files using ${VARIABLE_NAME}.
#
# Example custom variables:
# MY_DOCUMENTS_DIR=/home/user/Documents
# NAS_MOUNT_DIR=/mnt/nas/backups

# =================================================================
#               BITWARDEN CLI CONFIGURATION
# =================================================================

BW_API_URL=https://vault.bitwarden.com/api
BW_IDENTITY_URL=https://vault.bitwarden.com/identity
BW_ACCESS_TOKEN=                # Bitwarden Secrets Manager access token
BW_STATE_FILE=src/_tools/statefile.json
BW_SERIALS_TO_KEEP=5            # Max number of serial-numbered backups to keep; 0 = keep all
BW_VAULTS_DIR=vaults            # Directory where vault exports are saved

# Path to the Bitwarden CLI binary.
# Windows: use the local bundled copy (set up by setup.bat)
# Linux:   'bw' if installed globally, or a relative path
BW_CLI_PATH=src/_tools/bw/bw.exe       # Windows default
# BW_CLI_PATH=bw                       # Linux default (uncomment and comment line above)


# --- Personal Vault ---
BW_PERSONAL_CLIENT_ID_UUID=
BW_PERSONAL_CLIENT_SECRET_UUID=
BW_PERSONAL_MASTER_PASSWORD_UUID=
BW_PERSONAL_OUTPUT_FILENAME=personal.json
BW_PERSONAL_EXPORT_FORMAT=encrypted_json   # encrypted_json | json | csv | zip
BW_PERSONAL_IS_ORGANIZATION=false
BW_PERSONAL_ORGANIZATION_ID=

# --- Work Vault ---
BW_WORK_CLIENT_ID_UUID=
BW_WORK_CLIENT_SECRET_UUID=
BW_WORK_MASTER_PASSWORD_UUID=
BW_WORK_OUTPUT_FILENAME=work.json
BW_WORK_EXPORT_FORMAT=encrypted_json       # encrypted_json | json | csv | zip
BW_WORK_IS_ORGANIZATION=true
BW_WORK_ORGANIZATION_ID=


# =================================================================
#               RAINDROP.IO BACKUP CONFIGURATION
# =================================================================

RAINDROP_PERSONAL_API_TOKEN=
RAINDROP_WORK_API_TOKEN=
RAINDROP_BACKUP_DESTINATION=    # Where to save Raindrop backups (absolute path)
BACKUPS_TO_KEEP=2               # Max Raindrop backup zips to keep; 0 = keep all


# =================================================================
#               NOTIFICATION CONFIGURATION
#
#  Configure one or both channels. If both are set, both fire.
#  Default preference: Email on Windows, Telegram on Linux.
# =================================================================

# --- Telegram (default on Linux, also works on Windows) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Email / SMTP (default on Windows, also works on Linux) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465                  # 465 = SSL, 587 = TLS
EMAIL_SENDER=
EMAIL_PASSWORD=                 # App-specific password recommended
EMAIL_RECIPIENT=


# =================================================================
#               LOG ATTACHMENT CONFIGURATION
#            (applies to both Email and Telegram)
# =================================================================

# Comma-separated glob patterns. The newest matching file per pattern is attached.
EMAIL_ATTACH_LOGS=run_*.log, *2fa*.html, *backups*.html


# =================================================================
#               STATUS FILE PATHS (keep as default)
# =================================================================

# STATUS_FILE=status.json
# STATUS_DASHBOARD_FILE=status_dashboard.md


# =================================================================
#               END OF CONFIGURATION
# =================================================================