# =================================================================
#               MASTER AUTOMATION CONFIGURATION (LINUX)
# =================================================================

# --- Passwords ---
BITWARDEN_PERSONAL_PASSWORD=
BITWARDEN_WORK_PASSWORD=
KDBX_PERSONAL_PASSWORD=
KDBX_WORK_PASSWORD=

# --- Paths (Linux) ---
BW_EXPORT_SCRIPT_PATH=src/_tools/bitwarden_exporter.py
RAINDROP_BACKUP_SCRIPT_PATH=src/_tools/raindrop_backup.py

# --- SYNC SOURCES (Live data on your server) ---
# 1. 2FA Source: Where your 2FA files live on the drive
SYNC_2FA_SOURCE_DIR=/home/user/my_2fa_files

# 2. Backups Source: The parent folder containing Docs, Obsidian, Raindrop
SYNC_BACKUPS_SOURCE_DIR=/home/user/my_documents

# --- SYNC DESTINATIONS (Encrypted Links) ---
# These point to the symlinks created by run.sh
SYNC_2FA_DEST=2fa
SYNC_BACKUPS_DEST=backups

# --- Raindrop Configuration ---
RAINDROP_PERSONAL_API_TOKEN=
RAINDROP_WORK_API_TOKEN=
# Raindrop downloads to the SOURCE drive first (inside my_documents)
RAINDROP_BACKUP_DESTINATION=/home/user/my_documents/raindrop
BACKUPS_TO_KEEP=2

# --- Master Script Behavior ---
CONTINUE_ON_ERROR=true

# --- Bitwarden Configuration ---
BW_API_URL=https://vault.bitwarden.com/api
BW_IDENTITY_URL=https://vault.bitwarden.com/identity
BW_ACCESS_TOKEN=
BW_STATE_FILE=src/_tools/statefile.json
BW_CLI_PATH=/usr/local/bin/bw
# Bitwarden exports to the encrypted 'vaults' link
BW_VAULTS_DIR=vaults
BW_SERIALS_TO_KEEP=5

# Bitwarden Personal
BW_PERSONAL_CLIENT_ID_UUID=
BW_PERSONAL_CLIENT_SECRET_UUID=
BW_PERSONAL_MASTER_PASSWORD_UUID=
BW_PERSONAL_OUTPUT_FILENAME=personal.json
BW_PERSONAL_EXPORT_FORMAT=encrypted_json
BW_PERSONAL_IS_ORGANIZATION=false

# Bitwarden Work
BW_WORK_CLIENT_ID_UUID=
BW_WORK_CLIENT_SECRET_UUID=
BW_WORK_MASTER_PASSWORD_UUID=
BW_WORK_OUTPUT_FILENAME=work.json
BW_WORK_EXPORT_FORMAT=encrypted_json
BW_WORK_IS_ORGANIZATION=true
BW_WORK_ORGANIZATION_ID=

# ----- Telegram -----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Log files to be included ---
EMAIL_ATTACH_LOGS=run_*.log,sync-2fa*.*,sync-backups*.*
